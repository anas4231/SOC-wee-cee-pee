#define pb push_back
#define Sort(a) sort(a.begin(),a.end())
#define fo(i,n) for(long long i=0;i<n;i++)
#define read(a,n) for(long long i=0;i<n;i++){cin>>a[i];}
const int N=200001;
bool q(ll p,ll y,ll k,ll x){
    for(int i=0;i<x;i++){
        p=p-p/y;
        
    }
    if(p>=k)return 1;
    else return 0;
}

int main(){

	int t;
	cin>>t;
	while(t--){
	  ll x,y,k;
	  cin>>x>>y>>k;
	  ll l=0,r=1e12;
	  while(l<=r){
	      ll mid=(l+r)/2;
	       if(q(mid,y,k,x)){
	           r=mid-1;
	           
	       }
	       else l=mid+1;
	  }
	  if(q(l,y,k,x)==1 && l<=1e12)cout<<l<<endl;
	  else cout<<-1<<endl;
	}
	}
#include <bits/stdc++.h>
using namespace std;

typedef long long ll;
typedef long double ld;
typedef vector<int> vi;
typedef vector<ll> vll;
typedef pair<int,int> pii;
typedef pair<ll,ll> pll;
#define pb push_back
#define Sort(a) sort(a.begin(),a.end())
#define fo(i,n) for(long long i=0;i<n;i++)
#define read(a,n) for(long long i=0;i<n;i++){cin>>a[i];}
const int N=200001;

int main(){
    int n,m;
    cin>>n>>m;
    vector<pair<int,int>>adj[n+1];
    vi visited(n+1);
    for(int i=0;i<m;i++){
        int a,b,c;
        cin>>a>>b>>c;
        adj[a].pb({b,c});
    }
    
    vll dist(n+1);
    for(int i=1;i<=n;i++){
        dist[i]=1e18;
    }
    dist[1]=0;
    priority_queue<pair<ll,ll>>q;
    q.push({0,1});
    while(!q.empty()){
        int a=q.top().second;
        q.pop();
        if(visited[a])continue;
        visited[a]=1;
        for(auto x:adj[a]){
           
            int b=x.first,w=x.second;
            dist[b]=min(dist[b],dist[a]+w);
            q.push({-dist[b],b});
 }}
 for(int i=1;i<=n;i++){
     cout<<dist[i]<<" ";
 }
 cout<<endl;}
    
#include <bits/stdc++.h>
using namespace std;

typedef long long ll;
typedef long double ld;
typedef vector<int> vi;
typedef vector<ll> vll;
typedef pair<int,int> pii;
typedef pair<ll,ll> pll;
#define pb push_back
#define Sort(a) sort(a.begin(),a.end())
#define fo(i,n) for(long long i=0;i<n;i++)
#define read(a,n) for(long long i=0;i<n;i++){cin>>a[i];}
const int N=200001;
vi visited(N);
vi adj[N];
vi parent(N);
int c=0,d=0;
void dfs(int s,int p){
    if(visited[s])return;
    visited[s]=1;
    for(int x:adj[s]){
        if(x==p) continue;
        if(visited[x]){
        d=s;
        c=x; break;}
    parent[x]=s;
    dfs(x,s);
    if(c) return;
    
}}
int main(){
    int n,m;
    cin>>n>>m;
    for(int i=0;i<m;i++){
        int x,y;
        cin>>x>>y;
        adj[x].pb(y);
        adj[y].pb(x);
    }
    
    for(int i=1;i<=n;i++){
        if(c) break;
        if(visited[i]) continue;
       
        dfs(i,-1);
        
    }
    vi ans;
    if(c){
        for(int i=d;i!=c;i=parent[i]){
            ans.pb(i);
        }
        cout<<ans.size()+2<<endl;
        cout<<ans[ans.size()-1]<<" "<<c<<" ";
        for(int x:ans){
            cout<<x<<" ";
        }
    }
    else cout<<"IMPOSSIBLE";}
    

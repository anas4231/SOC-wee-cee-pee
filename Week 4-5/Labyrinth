#include <bits/stdc++.h>
using namespace std;

typedef long long ll;
typedef long double ld;
typedef vector<int> vi;
typedef vector<ll> vll;
typedef pair<int,int> pii;
typedef pair<ll,ll> pll;
#define pb push_back
#define Sort(a) sort(a.begin(),a.end())
#define fo(i,n) for(long long i=0;i<n;i++)
#define read(a,n) for(long long i=0;i<n;i++){cin>>a[i];}
const int N=200001;



int main(){
	int n,m;
	cin>>n>>m;
	vector<vector<int>>visited(n,vector<int>(m));
	vector<vector<int>>d(n,vector<int>(m));
	vector<vector<pair<int,int>>>p(n,vector<pair<int,int>>(m));
vector<vector<char>>a(n,vector<char>(m));
pair<int,int>x,b;
for(int i=0;i<n;i++){
	for(int j=0;j<m;j++){
		cin>>a[i][j];
		if(a[i][j]=='A')x={i,j};
		if(a[i][j]=='B')b={i,j};
	}
}

queue<pair<int,int>>q;
q.push(x);
 visited[x.first][x.second]=1;
while(!q.empty()){
 pair<int,int>w=q.front();
 int i=w.first;
 int j=w.second;

 q.pop();
 if(i-1>=0 && a[i-1][j]!='#' && !visited[i-1][j]){
	visited[i-1][j]=1;
	q.push({i-1,j});
	p[i-1][j]={i,j};
	d[i-1][j]=d[i][j]+1;
 }
 if(j-1>=0 && a[i][j-1]!='#' && !visited[i][j-1]){
	visited[i][j-1]=1;
	q.push({i,j-1});
	p[i][j-1]={i,j};
	d[i][j-1]=d[i][j]+1;
 }
 if(i+1<n && a[i+1][j]!='#' && !visited[i+1][j]){
	visited[i+1][j]=1;
	q.push({i+1,j});
	p[i+1][j]={i,j};
	d[i+1][j]=d[i][j]+1;
 }
 if(j+1<m && a[i][j+1]!='#' && !visited[i][j+1]){
	visited[i][j+1]=1;
	q.push({i,j+1});
	p[i][j+1]={i,j};
	d[i][j+1]=d[i][j]+1;
 }}
 if(d[b.first][b.second]==0)cout<<"NO"<<endl;
 else{
	cout<<"YES"<<endl;
 cout<<d[b.first][b.second]<<endl;
 string s="";
 for(pair<int,int>r=b;r!=x;r=p[r.first][r.second]){
 int i=r.first,j=r.second;
 int par1=p[i][j].first,par2=p[i][j].second;
 if(par1>i)s+='U';
 if(par1<i)s+='D';
 if(par2>j)s+='L';
 if(par2<j)s+='R';
 
}
reverse(s.begin(),s.end());
cout<<s<<endl;}}

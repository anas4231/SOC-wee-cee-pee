using namespace std;

int main() {
	// your code goes here
	int n;
	cin>>n;
	long long a[n],b[n];
	long long s=0;
	for(int i=0;i<n;i++){
	    cin>>a[i]>>b[i];
	    s+=b[i];
	}
	sort(a,a+n);
	long long  t=0;
	for(int i=0;i<n;i++){
	    t+=(n-i)*a[i];
	}
	cout<<s-t<<endl;


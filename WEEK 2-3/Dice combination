#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
int main() {
	ll n,x=1e9+7;
	cin>>n;
	if(n>6){

	ll f[n+1];
	f[1]=1;
	f[2]=2;
	f[3]=4;
	f[4]=8;
	f[5]=16;
	f[6]=32;
	for(int i=7;i<=n;i++){
		f[i]=f[i-1]%x+f[i-2]%x+f[i-3]%x+f[i-4]%x+f[i-5]%x+f[i-6]%x;
	}
	cout<<f[n]%x<<endl;}
	else cout<<pow(2,n-1)<<endl;}
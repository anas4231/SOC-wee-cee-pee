#include <bits/stdc++.h>
using namespace std;
typedef long long ll;

int main() {
	// your code goes here
	int n,x;
	ll m=1e9+7;
	cin>>n>>x;
	 int c[n];
	 for(int i=0;i<n;i++){
	     cin>>c[i];
	 }
	  ll f[x+1];
	  
	  f[0]=1;
	  for(int i=1;i<=x;i++){
       ll s=0;
	   for(int j=0;j<n;j++){
		if(i-c[j]>=0){
		s+=f[i-c[j]]%m;
	   }
	}
	f[i]=s%m;
	}
	cout<<f[x]<<endl;}

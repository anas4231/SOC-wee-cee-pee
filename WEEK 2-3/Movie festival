#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
int main() {
	ll n;
	cin>>n;
	vector<pair<ll,ll>>p(n);
	for(int i=0;i<n;i++){
		cin>>p[i].second>>p[i].first;
	}
	sort(p.begin(),p.end());
	ll c=1,l=0,r=1;
	while(l<n && r<n){
		if(p[r].second<p[l].first){
			r++;
		}
		else{
			c++;
			l=r;
			r++;
		}
	}
	cout<<c<<endl;}
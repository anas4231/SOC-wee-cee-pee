#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
int main() {
	ll n,x;
	cin>>n>>x;
	ll a[n];
	for (int i=0;i<n;i++){
	    cin>>a[i];
	}
	sort(a,a+n);
    ll c=0;
    ll l=0,r=n-1;
    while(l<r){
        if(a[l]+a[r]<=x){
            l++;
            r--;
            c++;
        }
        else {
            r--;}
        
    }
    cout<<n-c<<endl;
    
}

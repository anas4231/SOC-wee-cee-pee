#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
bool check(ll x,ll b){
	if(x>=b) return true;
	else return false;
	
}
int main(){
	ll n,q;
	cin>>n;
	ll a[n];
	for(int i=0;i<n;i++){
		cin>>a[i];
	}
	cin>>q;
	ll b[q];
	for(int i=0;i<q;i++){
		cin>>b[i];
	}
	sort(a,a+n);
    ll ans[q];
	for(int i=0;i<q;i++){
    ll l=0,r=n-1;
	while(r-l>1){
		ll mid=(l+r)/2;
		if(check(b[i],a[mid])){
			l=mid;
		}
		else r=mid-1;
	}
	if(check(b[i],a[r])){
		ans[i]=r+1;
	}
	else if(check(b[i],a[l])){
		ans[i]=l+1;
	}
	else {
		ans[i]=0;
	}
}
for(int i=0;i<q;i++){
    cout<<ans[i]<<endl;}


	}

	


class Solution {
public:
    int search(vector<int>& nums, int target){ 
     int n=nums.size();
    int l=0,r=n-1,ans=-1;
    while(l<=r){
       int  k=(l+r)/2;
        if(nums[k]==target) return k;
        else if(nums[k]>target) r=k-1;
        else l=k+1;
    }
    return ans;
    }
};
#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
int main(){
	ll n,q;
	cin>>n>>q;
	ll a[n],p[n];
	
	for(int i=0;i<n;i++){
		cin>>a[i];
		
		if(i!=0){
		p[i]=p[i-1]+a[i];}
		else{
			p[0]=a[0];
		}
	}
	ll x[q],y[q];
	for(int i=0;i<q;i++){
		cin>>x[i];
		cin>>y[i];
	}
	for(int i=0;i<q;i++){
		cout<<p[y[i]-1]-p[x[i]-1]+a[x[i]-1]<<endl;
	}

}
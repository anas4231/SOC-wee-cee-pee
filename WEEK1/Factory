#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
ll fun(ll x,ll a[], ll n,ll t){
    ll s=0;
    for(ll i=0;i<n;i++){
       s+=x/a[i]; 
    }
    return s-t;
}
int main() {
    ll n,t;
    cin>>n>>t;
    ll k[n];
    
    for(ll i=0;i<n;i++){
        cin>>k[i];
    }
    sort(k,k+n);
    ll z=k[0]*t;
    ll ans=-1;
    for(ll i=z;i>=1;i=i/2){
        while(fun(i+ans,k,n,t)<0)ans+=i;
    }
    cout<<ans+1<<endl;
    
    
}
